# DeepSeek API key for the /api/chat serverless proxy.
# Get one at https://platform.deepseek.com/  →  API Keys
# On Vercel: Project → Settings → Environment Variables → add DEEPSEEK_API_KEY
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: override the frontend endpoint the chat widget calls (defaults to /api/chat)
# VITE_CHAT_API_URL=/api/chat
